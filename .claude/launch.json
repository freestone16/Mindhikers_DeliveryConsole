{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Full Dev (Frontend + Backend)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5181
    },
    {
      "name": "Frontend Only (Vite)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host"],
      "port": 5181
    },
    {
      "name": "Backend Only (TSX Server)",
      "runtimeExecutable": "tsx",
      "runtimeArgs": ["watch", "server/index.ts"],
      "port": 3005
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3005
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host"],
      "port": 5181,
      "autoPort": false
    },
    {
      "name": "demo-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8765", "--directory", "docs/03_ui/demo"],
      "port": 8765
    }
  ]
}
