{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Full Dev (Frontend + Backend)",
      "runtimeExecutable": "zsh",
      "runtimeArgs": ["-i", "-c", "npm run dev"],
      "port": 5174
    },
    {
      "name": "Frontend Only (Vite)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host"],
      "port": 5173
    },
    {
      "name": "Backend Only (TSX Server)",
      "runtimeExecutable": "tsx",
      "runtimeArgs": ["watch", "server/index.ts"],
      "port": 3002
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3002
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "vite", "--", "--host"],
      "port": 5173
    }
  ]
}
