{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Full Dev (Frontend + Backend)",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "set -a; [ -f ./.env ] && . ./.env; [ -f ./.env.local ] && . ./.env.local; set +a; npm run dev"],
      "port": 5182
    },
    {
      "name": "Frontend Only (Vite)",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "set -a; [ -f ./.env ] && . ./.env; [ -f ./.env.local ] && . ./.env.local; set +a; npx vite --host --port ${VITE_APP_PORT:-5182}"],
      "port": 5182
    },
    {
      "name": "Backend Only (TSX Server)",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "set -a; [ -f ./.env ] && . ./.env; [ -f ./.env.local ] && . ./.env.local; set +a; npx tsx watch server/index.ts"],
      "port": 3009
    },
    {
      "name": "backend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "set -a; [ -f ./.env ] && . ./.env; [ -f ./.env.local ] && . ./.env.local; set +a; npx tsx watch server/index.ts"],
      "port": 3009
    },
    {
      "name": "frontend",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "set -a; [ -f ./.env ] && . ./.env; [ -f ./.env.local ] && . ./.env.local; set +a; npx vite --host --port ${VITE_APP_PORT:-5182}"],
      "port": 5182,
      "autoPort": false
    }
  ]
}
