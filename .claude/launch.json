{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Full Dev (Frontend + Backend)",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "PORT=3003 npm run dev"],
      "port": 5175
    },
    {
      "name": "Frontend Only (Vite)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--host"],
      "port": 5175
    },
    {
      "name": "Backend Only (TSX Server)",
      "runtimeExecutable": "tsx",
      "runtimeArgs": ["watch", "server/index.ts"],
      "port": 3003
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3003
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "vite", "--", "--host"],
      "port": 5175
    }
  ]
}
