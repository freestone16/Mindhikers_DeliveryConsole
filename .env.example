# 当前服务的默认工作区（对应 Projects/ 下的文件夹名）
PROJECT_NAME=golden-crucible-sandbox

# SaaS shell default ports
PORT=3010
VITE_APP_PORT=5183
VITE_BACKEND_PORT=3010
VITE_API_BASE_URL=http://localhost:3010
VITE_SOCKET_URL=http://127.0.0.1:3010
VITE_BACKEND_TARGET=http://127.0.0.1:3010

# Public app origin and CORS
APP_BASE_URL=http://localhost:5183
CORS_ORIGIN=http://localhost:5183

# Session secret for staging/demo deployment
SESSION_SECRET=replace-this-with-a-long-random-secret

# 项目基础路径
# Docker 容器内: /data/projects
# 本地开发: 可注释掉此行，自动 fallback 到 ../../Projects
# SaaS 主链后续应尽量减少对该变量的依赖
PROJECTS_BASE=/data/projects

# ========== LLM Provider API Keys ==========

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=

# Anthropic (Claude 3.5 Sonnet, Claude 3 Opus, etc.)
ANTHROPIC_API_KEY=

# Google (Gemini Pro, Gemini Flash, etc.)
GOOGLE_API_KEY=

# DeepSeek (国产替代)
DEEPSEEK_API_KEY=

# Zhipu AI (GLM-4, etc.)
ZHIPU_API_KEY=

# ========== Media Generation APIs ==========

# SiliconFlow (文生图/文生视频)
SILICONFLOW_API_KEY=

# Artlist (实拍素材搜索)
ARTLIST_API_KEY=
