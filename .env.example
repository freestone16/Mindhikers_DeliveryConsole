# 当前服务的默认工作区
# 未显式配置 PROJECTS_BASE 时，会自动落到 runtime/crucible/projects/<PROJECT_NAME>
PROJECT_NAME=golden-crucible-roundtable

# Roundtable shell default ports
PORT=3005
VITE_APP_PORT=5180
VITE_BACKEND_PORT=3005
VITE_API_BASE_URL=http://localhost:3005
VITE_SOCKET_URL=http://127.0.0.1:3005
VITE_BACKEND_TARGET=http://127.0.0.1:3005

# Public app origin and CORS
APP_BASE_URL=http://localhost:5180
CORS_ORIGIN=http://localhost:5180

# Session secret for local/demo deployment
SESSION_SECRET=replace-this-with-a-long-random-secret

# 项目基础路径（可选）
# Docker 容器内: /data/projects
# 本地开发: 可注释掉此行，自动 fallback 到 runtime/crucible/projects
# PROJECTS_BASE=/data/projects

# ========== LLM Provider API Keys ==========

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=

# Anthropic (Claude 3.5 Sonnet, Claude 3 Opus, etc.)
ANTHROPIC_API_KEY=

# Google (Gemini Pro, Gemini Flash, etc.)
GOOGLE_API_KEY=

# DeepSeek (国产替代)
DEEPSEEK_API_KEY=

# Zhipu AI (GLM-4, etc.)
ZHIPU_API_KEY=
