# 当前服务的内容项目名（对应 Projects/ 下的文件夹名）
PROJECT_NAME=CSET-SP3

# 服务端口
PORT=3002

# 项目基础路径
# Docker 容器内: /data/projects
# 本地开发: 注释掉此行，自动 fallback 到 ../../Projects
PROJECTS_BASE=/data/projects

# ========== LLM Provider API Keys ==========

# OpenAI (GPT-4o, GPT-4o-mini, etc.)
OPENAI_API_KEY=

# Anthropic (Claude 3.5 Sonnet, Claude 3 Opus, etc.)
ANTHROPIC_API_KEY=

# Google (Gemini Pro, Gemini Flash, etc.)
GOOGLE_API_KEY=

# DeepSeek (国产替代)
DEEPSEEK_API_KEY=

# Zhipu AI (GLM-4, etc.)
ZHIPU_API_KEY=

# ========== Media Generation APIs ==========

# SiliconFlow (文生图/文生视频)
SILICONFLOW_API_KEY=

# Artlist (实拍素材搜索)
ARTLIST_API_KEY=
