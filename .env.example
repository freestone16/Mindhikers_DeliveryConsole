# director0309 worktree — 端口配置模板
# 复制为 .env 并填入实际值，不要提交 .env 本身
# 端口已在 ~/.vibedir/global_ports_registry.yml 备案

PROJECT_NAME=MindHikers Delivery Console

# 后端端口
PORT=3003

# 前端 Vite 端口
VITE_PORT=5175

# 前端 API Base — 开发时留空走 Vite proxy，生产时填实际 host
VITE_API_BASE=

# 项目数据目录
PROJECTS_BASE=/path/to/your/Projects
