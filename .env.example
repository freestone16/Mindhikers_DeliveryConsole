# Director 新家工作区 — 端口配置模板
# 复制为 .env.local 并填入账本分配的实际值，不要再把端口写死到代码或脚本里
# 端口 SSOT: ~/.vibedir/global_ports_registry.yml -> .env.local -> runtime

PROJECT_NAME=MindHikers Delivery Console

# 后端端口（按账本执行）
PORT=3005

# 前端/后端运行时端口
VITE_BACKEND_PORT=3005
VITE_APP_PORT=5178
VITE_PORT=5178

# 前端 API Base — 开发时留空走 Vite proxy，生产时填实际 host
VITE_API_BASE=

# 项目数据目录
PROJECTS_BASE=/path/to/your/Projects

# LLM
LLM_PROVIDER=siliconflow
DEEPSEEK_API_KEY=
SILICONFLOW_API_KEY=
KIMI_API_KEY=
YINLI_API_KEY=

# Volcengine (image/video generation)
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
VOLCENGINE_PROJECT_ID=
VOLCENGINE_ENDPOINT_ID_IMAGE=
VOLCENGINE_ENDPOINT_ID_VIDEO=

# Skills 路径
SKILLS_BASE=/path/to/your/.agent/skills

# TubeBuddy (1 = mock mode，跳过 Playwright；留空 = 真实模式)
TUBEBUDDY_DEV_MOCK=1
