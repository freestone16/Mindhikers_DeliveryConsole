# Backend Dockerfile for Delivery Console
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies (including devDependencies for tsx)
RUN npm install
RUN npm install -g tsx

# Copy source code
COPY . .

# Expose backend port
EXPOSE 3002

# Default command (can be overridden in docker-compose)
CMD ["npx", "tsx", "server/index.ts"]
