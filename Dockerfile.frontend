# Frontend Dockerfile for Delivery Console
FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install
RUN npm install -g concurrently

# Copy source code
COPY . .

# Expose Vite dev server port
EXPOSE 5178

# Default command (can be overridden in docker-compose)
CMD ["npm", "run", "dev"]
